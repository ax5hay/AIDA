# Database (required for Prisma)
# With docker-compose.yml: postgresql://aida:aida@localhost:5432/aida
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aida

# API
API_PORT=4000
WEB_ORIGIN=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# Optional GenAI (system works with AI disabled)
AI_INSIGHTS_ENABLED=false
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=local-model
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
