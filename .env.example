# Database (required for Prisma)
# With docker-compose.yml: postgresql://aida:aida@localhost:5432/aida
DATABASE_URL=postgresql://aida:aida@localhost:5432/aida

# API
API_PORT=4000
# Max JSON/urlencoded body size (AI POSTs send large intelligence snapshots)
API_BODY_LIMIT=50mb
INGESTION_API_KEY=
MAX_FILTER_WINDOW_DAYS=365
MAX_ANALYTICS_ROWS=5000
MAX_EXPLORER_PAGE_SIZE=500
# Browser origin allowed by CORS. For ngrok, set to your HTTPS web tunnel (e.g. https://xxxx.ngrok-free.app).
WEB_ORIGIN=http://localhost:3000
# Optional: ngrok CLI (scripts/ngrok-dev.sh). Get token from https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=

# Web
# Default points to Next.js rewrite /api/* -> localhost:4000/*, so one ngrok tunnel can serve web+api.
# If you prefer direct API calls, set an absolute URL ending in /v1.
NEXT_PUBLIC_API_URL=/api/v1

# Optional GenAI (system works with AI disabled)
AI_INSIGHTS_ENABLED=true
LM_STUDIO_BASE_URL=http://127.0.0.1:1234
LM_STUDIO_MODEL=liquid/lfm2.5-1.2b
# LLM input shaping (fits small local models, e.g. n_ctx=4096)
AI_LLM_CONTEXT_TOKENS=4096
AI_PROMPT_RESERVE_TOKENS=1000
AI_USER_CONTENT_MAX_CHARS=6000
AI_CHARS_PER_TOKEN_ESTIMATE=4
AI_MODEL_LIST_TIMEOUT_MS=4000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
