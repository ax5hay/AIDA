# =============================================================================
# AIDA monorepo — environment (copy to `.env` and adjust)
# Demo reference: https://aida-demo.merakiel.in · https://parity-demo.merakiel.in
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://aida:aida@localhost:5432/aida

# -----------------------------------------------------------------------------
# Cross-product URLs (Parity ↔ AIDA)
# -----------------------------------------------------------------------------
# Prefer AIDA_WEB_URL / PARITY_WEB_URL for hub & sidebar (runtime; not build-inlined).
# Local: http://localhost:3000 / http://localhost:3001
# Cloudflare demo: https://aida-demo.merakiel.in / https://parity-demo.merakiel.in
AIDA_WEB_URL=http://localhost:3000
# NEXT_PUBLIC_AIDA_WEB_URL=http://localhost:3000

PARITY_WEB_URL=http://localhost:3001
# NEXT_PUBLIC_PARITY_WEB_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# API (Nest — apps/api)
# -----------------------------------------------------------------------------
API_PORT=4000
API_BODY_LIMIT=50mb
INGESTION_API_KEY=

MAX_FILTER_WINDOW_DAYS=365
MAX_ANALYTICS_ROWS=5000
MAX_EXPLORER_PAGE_SIZE=500

# Must match the browser origin that calls the API (ngrok/tunnel: use that HTTPS origin).
WEB_ORIGIN=http://localhost:3000

# Optional: ngrok CLI (scripts/ngrok-dev.sh)
# NGROK_AUTHTOKEN=

# -----------------------------------------------------------------------------
# Web clients (AIDA + Parity)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_PARITY_API_URL=/api/v1

# -----------------------------------------------------------------------------
# GenAI (optional)
# -----------------------------------------------------------------------------
AI_INSIGHTS_ENABLED=true
LM_STUDIO_BASE_URL=http://127.0.0.1:1234
LM_STUDIO_MODEL=liquid/lfm2.5-1.2b
AI_LLM_CONTEXT_TOKENS=4096
AI_PROMPT_RESERVE_TOKENS=1000
AI_USER_CONTENT_MAX_CHARS=6000
AI_CHARS_PER_TOKEN_ESTIMATE=4
AI_MODEL_LIST_TIMEOUT_MS=4000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
