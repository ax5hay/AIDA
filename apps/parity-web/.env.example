# Parity API base path. Leave unset for local + tunnel demos: Next proxies /api/v1 → Parity API (see next.config).
# NEXT_PUBLIC_PARITY_API_URL=/api/v1
# Only if the browser must call another origin (rare):
# NEXT_PUBLIC_PARITY_API_URL=https://parity-api-demo.example.com/v1

# Where Next.js rewrites /api/v1 → Parity API (dev server / Node only; not exposed to the browser).
# PARITY_API_INTERNAL_URL=http://127.0.0.1:4010

# Full AIDA web URL for the product hub “Launch AIDA” card
NEXT_PUBLIC_AIDA_WEB_URL=http://localhost:3000
